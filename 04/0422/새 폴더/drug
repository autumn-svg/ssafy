# 인풋 받기!
T = int(input())
for test_case in range(1, T + 1):
    D, W, K = map(int, input().split())

    film = [list(map(int, input().split())) for _ in range(D)]

    # 투약을 몇번하는지 정답!
    # K 번 이상하면 무조건 정답이기 때문에
    # K 로 설정하고 def check_film 짜러가기
    result = K

    if check_film():
        result = 0

    else:
        dfs(0, 0)

    print(f"#{test_case}", result)

